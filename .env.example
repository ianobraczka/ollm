# Google Gemini API key (required)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: preferred first model (503 falls back automatically)
# Default chain: gemini-2.5-flash-lite → gemini-2.5-flash → gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# Schoology API (two-legged OAuth 1.0 — personal API credentials)
# https://developers.schoology.com/api-documentation/rest-api-v1/
SCHOOLOGY_BASE_URL=https://api.schoology.com/v1
SCHOOLOGY_CONSUMER_KEY=
SCHOOLOGY_CONSUMER_SECRET=

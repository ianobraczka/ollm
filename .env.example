# Google Gemini API key (required)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: preferred first model (503 falls back automatically)
# Default chain: gemini-2.5-flash-lite → gemini-2.5-flash → gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# Schoology REST API (required for Assessment Assistant)
# Server-side only: signed fetch to api.schoology.com — no Playwright or page scraping.
# Two-legged OAuth 1.0: consumer key/secret in .env.local (no browser OAuth redirect).
# Obtain keys at Schoology → Integration → API (/api). Platform App keys are three-legged only.
SCHOOLOGY_BASE_URL=https://api.schoology.com/v1
SCHOOLOGY_CONSUMER_KEY=your_consumer_key_here
SCHOOLOGY_CONSUMER_SECRET=your_consumer_secret_here

# Optional: Schoology web UI host for "Open in Schoology" links (not the REST API).
# SCHOOLOGY_DOMAIN=https://app.schoology.com

# Enable structured debug logs (data/schoology-debug.log)
# SCHOOLOGY_DEBUG=1
